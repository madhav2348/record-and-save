---
const title = 'Record and Save';
const description = 'A simple Chrome extension for recording the active tab and saving the result locally.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<p class="eyebrow">Chrome extension</p>
			<h1>{title}</h1>
			<p class="summary">{description}</p>
			<a href="https://github.com/madhav2348/record-and-save">View project</a>
		</main>
	</body>
</html>

<style>
	:root {
		color: #1c1f23;
		background: #f7f4ef;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	body {
		min-height: 100vh;
		margin: 0;
		display: grid;
		place-items: center;
	}

	main {
		width: min(100% - 2rem, 42rem);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: #53606c;
		font-size: 0.875rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.75rem, 9vw, 6rem);
		line-height: 0.95;
		letter-spacing: 0;
	}

	.summary {
		max-width: 34rem;
		margin: 1.25rem 0 2rem;
		color: #49515a;
		font-size: 1.125rem;
		line-height: 1.7;
	}

	a {
		display: inline-flex;
		align-items: center;
		min-height: 2.75rem;
		padding: 0 1rem;
		border: 1px solid #1c1f23;
		border-radius: 0.375rem;
		color: #1c1f23;
		font-weight: 700;
		text-decoration: none;
	}

	a:hover,
	a:focus-visible {
		background: #1c1f23;
		color: #fff;
	}
</style>
